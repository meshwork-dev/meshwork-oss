      "id": "705dc982-1f07-43df-a596-3082edd65377",
      "name": "Post to Engineering Space",
      "credentials": {
        "telegramApi": {
          "id": "",
          "name": ""
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Optional: Dispatch product-manager to prioritize oldest stale items\nconst staleItems = $json.staleItems || [];\n\n// Only dispatch for items stale > 60 days\nconst veryStale = staleItems.filter(item => item.daysSinceUpdate > 60);\n\nif (veryStale.length === 0) {\n  return [{ json: { skip: true } }];\n}\n\n// Return items to dispatch for review\nreturn veryStale.slice(0, 3).map(item => ({\n  json: {\n    skip: false,\n    issueKey: item.key,\n    reason: `Item stale for ${item.daysSinceUpdate} days - needs prioritization review`\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -112,
        96
      ],
      "id": "2d603df7-a413-47b4-9f86-124aca9aafe6",
