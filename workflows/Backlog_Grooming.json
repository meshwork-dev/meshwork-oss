      "id": "c0cf3175-9696-4559-8435-6b2608091ed5",
      "name": "Query Stale Backlog Items",
      "credentials": {
        "jiraSoftwareCloudApi": {
          "id": "",
          "name": ""
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Process stale backlog items\nconst items = $input.all();\n\nif (items.length === 0) {\n  return [{ json: { skip: true, reason: 'No stale items found' } }];\n}\n\n// Build summary of stale items\nconst staleItems = items.map(item => {\n  const issue = item.json;\n  const daysSinceUpdate = Math.floor((Date.now() - new Date(issue.fields?.updated).getTime()) / (1000 * 60 * 60 * 24));\n  return {\n    key: issue.key,\n    summary: issue.fields?.summary || 'No summary',\n    priority: issue.fields?.priority?.name || 'None',\n    daysSinceUpdate,\n    assignee: issue.fields?.assignee?.displayName || 'Unassigned'\n  };\n});\n\n// Build Google Chat message\nconst header = `*Backlog Grooming Alert*\\nFound ${staleItems.length} items that haven't been updated in 30+ days:\\n`;\nconst itemLines = staleItems.slice(0, 15).map(item => \n  `- ${item.key} (https://meshwork.atlassian.net/browse/${item.key}): ${item.summary.slice(0, 50)}${item.summary.length > 50 ? '...' : ''} (${item.daysSinceUpdate}d stale)`\n).join('\\n');\n\nconst footer = staleItems.length > 15 ? `\\n\\n_...and ${staleItems.length - 15} more items_` : '';\n\nreturn [{\n  json: {\n    skip: false,\n    staleCount: staleItems.length,\n    message: header + itemLines + footer,\n    staleItems: staleItems.slice(0, 10) // For potential dispatch\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -560,
        0
      ],
      "id": "8ed41641-fa09-4d66-9b6f-48d9002b720c",
      "name": "Build Stale Summary"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "id": "has-stale",
              "leftValue": "={{ !$json.skip }}",
              "rightValue": "",
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        -336,
