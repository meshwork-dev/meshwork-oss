{
  "name": "Z.ai Creative Assets MCP",
  "nodes": [
    {
      "parameters": {
        "authentication": "bearerAuth",
        "path": "zai-creative-mcp"
      },
      "type": "@n8n/n8n-nodes-langchain.mcpTrigger",
      "typeVersion": 2,
      "position": [
        400,
