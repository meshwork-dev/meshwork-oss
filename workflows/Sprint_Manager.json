          }
        ],
        [
          {
            "node": "Start Sprint",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Move to Sprint": {
      "main": [
        [
          {
            "node": "Start Sprint",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Start Sprint": {
      "main": [
        [
          {
            "node": "Build Summary",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Build Summary": {
      "main": [
        [
          {
            "node": "Send to Engineering",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
