          { "name": "decision_maker_contact",   "points": 15,  "source": "linkedin",         "description": "IT Manager or compliance role identified" },
          { "name": "company_size_fit",         "points": 10,  "source": "enrichment",       "description": "Company size 20-100 employees" },
