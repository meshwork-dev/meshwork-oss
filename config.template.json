{
  "port": 3210,
  "host": "0.0.0.0",
  "jobTimeoutMinutes": 60,
  "maxConcurrencyPerProduct": 1,
  "maxRetries": 3,
  "sseEnabled": true,
  "convStaleDays": 30,
  "jobStateRetentionDays": 7,
  "convTurns": 16,
  "convMaxChars": 24000,
  "idempotencyTtlHours": 72,
  "workingDir": "__WORKING_DIR__",
  "callbackUrl": "__N8N_PUBLIC_URL__/webhook/runner/callback",
  "logDir": "~/claude-runner-logs",
  "convDir": "~/claude-runner-logs/conversations",
  "sharedSkillsDir": "shared-skills",
  "allowedRoots": [],
  "tokenPricing": {
    "inputPerMillion": 15.00,
    "outputPerMillion": 75.00
  },
  "protectHealthEndpoint": true,
  "protectDashboard": true,
  "dashboardOrigins": ["http://localhost:3100"],
  "dashboardUrl": "http://localhost:3100",
  "logRetentionDays": 30,
  "alerting": {
    "slackWebhookUrl": null
  },
  "budget": {
    "enabled": true,
    "dailyLimitUsd": 300,
    "hourlyLimitUsd": 40
  },
  "providers": {
    "claude": {
      "baseUrl": null,
      "authTokenEnvVar": "ANTHROPIC_API_KEY"
    },
    "zai": {
      "baseUrl": "https://api.z.ai/api/anthropic",
      "authTokenEnvVar": "ZAI_API_KEY",
      "timeoutMs": 3000000,
      "modelMapping": {
        "opus": "GLM-5.1",
        "sonnet": "GLM-5.1",
        "haiku": "GLM-5.1"
      }
    }
  },
  "claude": {
    "command": "claude",
    "baseArgs": ["--dangerously-skip-permissions", "--plugin-dir", "__PLUGIN_DIR__"],
    "models": {
      "opus": "claude-opus-4-7",
      "sonnet": "claude-sonnet-4-6",
      "haiku": "claude-haiku-4-5-20251001"
    }
  },
  "routing": {
    "enabled": true,
    "agentToProvider": {
      "creative-assets": "zai"
    },
    "agentToModel": {
      "engineer-planner": "opus",
      "engineer-implementer": "sonnet",
      "engineer-reviewer": "opus",
      "product-manager": "opus",
      "marketing": "sonnet",
      "bug-triage": "opus",
      "sprint-reporter": "sonnet",
      "ui-engineer": "sonnet",
      "creative-assets": "haiku",
      "sales-development": "opus",
      "sales-researcher": "sonnet",
      "sales-outreach": "sonnet",
      "ba-agent": "opus",
      "architect-jets": "opus",
      "ux-agent": "sonnet",
      "qa-agent": "sonnet",
      "security-agent": "sonnet",
      "ask-tom-agent": "opus",
      "e2e-builder": "opus",
      "uat-agent": "sonnet",
      "user-guide-agent": "sonnet",
      "video-renderer": "sonnet"
    },
    "agentEffort": {
      "engineer-planner": "xhigh",
      "architect-jets": "xhigh",
      "product-manager": "xhigh",
      "engineer-reviewer": "xhigh",
      "ask-tom-agent": "xhigh",
      "e2e-builder": "xhigh",
      "engineer-implementer": "high"
    },
    "modeDefaults": {
      "delivery": "sonnet",
      "chat": "haiku"
    },
    "agentToolRestrictions": {
      "engineer-reviewer": {
        "disallowedTools": ["Edit", "Write", "NotebookEdit", "Bash"]
      }
    }
  },
  "qualityGate": {
    "enabled": true,
    "runAfterAgents": ["engineer-implementer", "e2e-builder"],
    "checks": [
      { "name": "type-check", "cmd": "npm run type-check", "required": true },
      { "name": "lint", "cmd": "npm run lint", "required": true },
      { "name": "test", "cmd": "npm test", "required": true }
    ],
    "maxRetries": 2,
    "retryWithContext": true
  },
  "fixLoop": {
    "enabled": true,
    "maxAttempts": 3,
    "gateTypes": ["quality-gate"],
    "maxVerifyAttempts": 3
  },
  "chrome": {
    "enabled": true,
    "acceptanceAgents": ["product-manager", "uat-agent", "user-guide-agent"]
  },
  "devServer": {
    "startCommand": "pnpm dev",
    "frontendUrl": "http://localhost:3000",
    "backendUrl": "http://localhost:3001",
    "healthCheckUrl": "http://localhost:3000",
    "healthCheckTimeout": 60000
  },
  "agentMcps": {
    "_default": null,
    "engineer-planner": ["memory", "runner-admin", "github", "sequential-thinking", "context7"],
    "engineer-implementer": ["memory", "runner-admin", "github", "context7"],
    "engineer-reviewer": ["memory", "runner-admin", "github"],
    "ui-engineer": ["memory", "runner-admin", "github", "context7", "playwright"],
    "product-manager": ["memory", "runner-admin"],
    "bug-triage": ["memory", "runner-admin", "github"],
    "security-agent": ["memory", "runner-admin", "snyk", "github"],
    "marketing": ["memory", "runner-admin", "fetch"],
    "creative-assets": ["memory", "runner-admin", "n8n-zai-mcp"],
    "sprint-reporter": ["memory", "runner-admin"],
    "sales-development": ["memory", "runner-admin", "attio-mcp"],
    "sales-researcher": ["memory", "runner-admin", "attio-mcp", "fetch"],
    "sales-outreach": ["memory", "runner-admin", "attio-mcp"],
    "ba-agent": ["memory", "runner-admin", "context7"],
    "architect-jets": ["memory", "runner-admin", "context7", "sequential-thinking"],
    "ux-agent": ["memory", "runner-admin", "context7"],
    "qa-agent": ["memory", "runner-admin", "playwright", "github"],
    "ask-tom-agent": ["memory", "runner-admin", "sequential-thinking", "github"],
    "e2e-builder": ["memory", "runner-admin", "github", "context7", "playwright"],
    "uat-agent": ["memory", "runner-admin", "playwright", "github"]
  },
  "subtasks": {
    "enabled": true,
    "maxConcurrency": 3,
    "maxPerParent": 3,
    "maxDepth": 3,
    "parallelAgents": ["engineer-implementer", "ui-engineer", "creative-assets", "marketing", "sales-researcher", "sales-outreach"]
  },
  "teams": {
    "enabled": true,
    "teamLeads": {
      "engineer-planner": {
        "teammates": ["engineer-implementer", "ui-engineer", "engineer-reviewer"],
        "teammateMode": "in-process"
      },
      "product-manager": {
        "teammates": ["ba-agent"],
        "teammateMode": "in-process"
      },
      "sales-development": {
        "teammates": ["sales-researcher", "sales-outreach"],
        "teammateMode": "in-process"
      }
    }
  },
  "verticals": {
