  "salesMarketing": {
    "linkedin": {
      "enabled": true,
      "postingCadence": "3x-week",
      "postingDays": ["monday", "wednesday", "friday"],
      "postingTime": "09:00",
      "monitorAccounts": [
        { "name": "IASME", "url": "https://www.linkedin.com/company/iasme-consortium/", "rssAlternative": "https://iasme.co.uk/feed/", "topics": ["cyber essentials", "CE Plus", "IASME Governance"] },
        { "name": "NCSC", "url": "https://www.linkedin.com/company/national-cyber-security-centre/", "rssAlternative": "https://www.ncsc.gov.uk/api/1/services/v1/report-rss-feed.xml", "topics": ["cyber threats", "guidance", "supply chain", "SME security"] },
        { "name": "ICO", "url": "https://www.linkedin.com/company/information-commissioner's-office/", "rssAlternative": "https://ico.org.uk/about-the-ico/media-centre/news-and-blogs/rss/", "topics": ["data protection", "GDPR", "enforcement", "SME guidance"] },
        { "name": "MOD Digital", "url": "https://www.linkedin.com/company/ministry-of-defence/", "rssAlternative": null, "topics": ["digital transformation", "defence supply chain", "DEFCON 658"] },
        { "name": "Def Stan", "url": null, "rssAlternative": "https://www.gov.uk/government/organisations/defence-equipment-and-support.atom", "topics": ["defence standards", "Def Stan 05-138", "procurement"] },
        { "name": "ADS Group", "url": "https://www.linkedin.com/company/ads-group-ltd/", "rssAlternative": "https://www.adsgroup.org.uk/feed/", "topics": ["aerospace", "defence", "security industry"] }
      ],
      "commentStyle": {
        "tone": "authoritative but approachable",
        "maxLength": 300,
        "includeQuestion": true,
        "avoidPhrases": ["Great post!", "Interesting!", "Thanks for sharing!", "Couldn't agree more!"],
        "brandVoice": "CertPilot helps UK defence SMEs achieve Cyber Essentials and Def Stan compliance. We speak from practitioner experience, not vendor marketing."
      },
      "postTypes": {
        "insight": { "frequency": 1, "description": "Industry insight or opinion on compliance/cyber trend" },
        "educational": { "frequency": 1, "description": "How-to or explainer about CE/DCC/Def Stan process" },
        "engagement": { "frequency": 1, "description": "Question, poll, or discussion starter about defence supply chain challenges" }
      },
      "confluenceQueue": {
        "space": "MKTG",
        "parentPage": "Social Media/LinkedIn Queue",
        "commentDraftsPage": "Social Media/LinkedIn Queue/Comment Drafts",
        "postDraftsPage": "Social Media/LinkedIn Queue/Post Drafts"
      },
      "slackChannel": "#marketing"
    },
    "mqlThreshold": 80,
    "mqlRequiresRecentSignal": true,
    "mqlSignalWindowDays": 14,
    "sqlSlaHours": 48,
    "outreachDecayDays": 21,
    "outreachDecayPoints": -10,
    "abm": {
      "maxTargets": 10,
      "expirationDays": 30,
      "minScore": 90
    },
    "contentRepurposing": {
      "blogToLinkedIn": 3,
      "blogToEmail": 1,
      "landingPageToLinkedIn": 2,
      "caseStudyToLinkedIn": 2,
      "caseStudyToEmail": 2
    },
    "seoReporting": {
      "schedule": "tuesday_0900",
      "staleContentDays": 90
    },
    "competitorIntel": {
      "schedule": "first_wednesday_monthly",
      "competitors": [
        { "name": "Vanta", "url": "https://vanta.com", "monitor": ["pricing", "features", "blog"] },
        { "name": "Drata", "url": "https://drata.com", "monitor": ["pricing", "features", "blog"] },
        { "name": "Secureframe", "url": "https://secureframe.com", "monitor": ["pricing", "features", "blog"] },
        { "name": "Tugboat Logic", "url": "https://tugboatlogic.com", "monitor": ["uk_presence"] }
      ]
    },
    "winLossAnalysis": {
      "schedule": "first_monday_monthly",
      "winReasons": ["Price", "Def Stan expertise", "Multi-framework", "Speed to certify", "Ease of use", "Referral", "Other"],
      "lossReasons": ["Budget", "Timeline", "Competitor - Vanta", "Competitor - Drata", "Competitor - Secureframe", "Competitor - Consultancy", "No compliance need", "No response", "Other"],
      "competitorAlertThreshold": 3
    }
  },
  "pipelines": {
    "new-feature": {
      "description": "Lean execution: implement → code-review → verify. Planning/requirements/UX happen in agent meetings.",
      "phases": [
        {
          "name": "implementation",
          "agent": "engineer-implementer",
          "model": "sonnet",
          "team": false,
          "worktree": true,
          "gate": { "type": "quality-gate" },
          "contextExtract": { "type": "jira-comments", "prefixes": ["[AUTO-PLAN]", "[AUTO-IMPLEMENT]"] }
        },
        {
          "name": "code-review",
          "agent": "engineer-reviewer",
          "model": "sonnet",
          "gate": { "type": "comment-prefix", "prefix": "[AUTO-REVIEW]" }
        },
        {
          "name": "verify",
          "agent": "qa-agent",
          "model": "sonnet",
          "gate": { "type": "comment-prefix", "prefix": "[AUTO-VERIFY]" }
        }
      ]
    },
    "bug-fix": {
      "description": "Lean bug fix: implement + code review + verify",
      "phases": [
        {
          "name": "implementation",
          "agent": "engineer-implementer",
          "model": "sonnet",
          "team": false,
          "worktree": true,
          "gate": { "type": "quality-gate" }
        },
        {
          "name": "code-review",
          "agent": "engineer-reviewer",
          "model": "sonnet",
          "gate": { "type": "comment-prefix", "prefix": "[AUTO-REVIEW]" }
        },
        {
          "name": "verify",
          "agent": "qa-agent",
          "model": "sonnet",
          "gate": { "type": "comment-prefix", "prefix": "[AUTO-VERIFY]" }
        }
      ]
    },
    "security-fix": {
      "description": "Security vulnerability fix",
      "phases": [
        {
          "name": "implementation",
          "agent": "engineer-implementer",
          "model": "sonnet",
          "team": false,
          "worktree": true,
          "gate": { "type": "quality-gate" }
        },
        {
          "name": "security-review",
          "agent": "security-agent",
          "model": "sonnet",
          "gate": { "type": "comment-prefix", "prefix": "[AUTO-SECURITY-REVIEW]" }
        },
        {
          "name": "verify",
          "agent": "qa-agent",
          "model": "sonnet",
          "gate": { "type": "comment-prefix", "prefix": "[AUTO-VERIFY]" }
        }
      ]
    },
    "design-bootstrap": {
      "description": "Design system bootstrap for greenfield products — establishes Tailwind theme, design tokens, and base component library",
      "phases": [
        {
          "name": "design-system",
          "agent": "ux-agent",
          "model": "sonnet",
          "gate": { "type": "comment-prefix", "prefix": "[AUTO-DESIGN-SYSTEM]" },
          "contextExtract": { "type": "file-summary" }
        },
        {
          "name": "component-scaffold",
          "agent": "ui-engineer",
          "model": "sonnet",
          "worktree": true,
          "gate": { "type": "quality-gate" }
        },
        {
          "name": "acceptance",
          "agent": "product-manager",
          "model": "opus",
          "gate": { "type": "comment-prefix", "prefix": "[AUTO-ACCEPT]" }
        }
      ]
    },
    "subtask": {
      "description": "Single implementation phase for subtask execution — shares worktree with parent story, auto-merges on completion",
      "phases": [
        {
          "name": "implementation",
          "agent": "engineer-implementer",
          "model": "sonnet",
          "team": false,
          "worktree": true,
          "gate": { "type": "quality-gate" },
          "contextExtract": { "type": "jira-comments", "prefixes": ["[AUTO-PLAN]", "[AUTO-IMPLEMENT]"] }
        }
      ]
    }
  },
  "contextBridge": {
    "enabled": true,
    "maxSummaryWords": 300,
    "compactMaxWords": 120,
    "phaseExtractors": {
      "triage": {
        "sections": ["decisions", "selectedPhases", "risks", "handoff"],
        "instruction": "Extract: key decisions, which pipeline phases were selected and why, risks/blockers identified, and specific handoff notes for the next phase."
      },
      "requirements": {
        "sections": ["acceptanceCriteria", "nfrs", "assumptions", "handoff"],
        "instruction": "Extract: acceptance criteria (numbered), non-functional requirements, assumptions made, and handoff notes for architecture/implementation."
      },
      "architecture": {
        "sections": ["decisions", "components", "interfaces", "risks", "handoff"],
        "instruction": "Extract: architecture decisions (with rationale), key components/services, interfaces/APIs defined, technical risks, and implementation handoff notes."
      },
      "ux-design": {
        "sections": ["components", "interactions", "accessibility", "handoff"],
        "instruction": "Extract: UI components specified, key interactions/flows, accessibility requirements, and implementation handoff (design tokens, breakpoints, etc)."
      },
      "implementation": {
        "sections": ["filesChanged", "approach", "testsCoverage", "handoff"],
        "instruction": "Extract: files created/modified (list paths), implementation approach taken, test coverage added, and notes for reviewer."
      },
      "code-review": {
        "sections": ["verdict", "issues", "suggestions"],
        "instruction": "Extract: review verdict (approve/request-changes), issues found with severity, and improvement suggestions."
      },
      "security-review": {
        "sections": ["verdict", "vulnerabilities", "recommendations"],
        "instruction": "Extract: security verdict, vulnerabilities found (with CVSS if available), and remediation recommendations."
      },
      "verify": {
        "sections": ["testResults", "coverage", "regressions", "browserTests", "issues"],
        "instruction": "Extract: test results summary (pass/fail counts), coverage metrics, regression status, browser/Playwright test results if run, and issues/bugs found."
      },
      "acceptance": {
        "sections": ["verdict", "releaseNotes", "followUp"],
        "instruction": "Extract: acceptance verdict, release notes summary, and follow-up items."
      }
    }
  },
  "dependencyGating": {
    "enabled": true,
    "checkGitMerge": true,
    "recheckIntervalSeconds": 60,
    "maxBlockedMinutes": 120
  },
  "worktrees": {
    "enabled": true,
    "baseDir": "~/certpilot-worktrees",
    "maxPerRepo": 20,
    "pruneOnStartup": true
  },
  "sprintRunner": {
    "enabled": true,
    "intervalMinutes": 10,
    "dispatchStatuses": ["To Do"],
    "skipLabels": ["on-hold", "blocked"],
