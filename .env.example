# =============================================================================
# OrchestraCode-AutoDev Environment Configuration
# Copy to .env and fill in values: cp .env.example .env
# =============================================================================

# ── Required ─────────────────────────────────────────────────────────────────
RUNNER_SECRET=your-runner-secret-min-16-chars
DASHBOARD_PASSWORD=your-dashboard-password

# ── Database (bundled by default; switch to external by editing these) ───────
POSTGRES_MODE=bundled
RUNNER_DB_HOST=postgres
RUNNER_DB_PORT=5432
RUNNER_DB_NAME=runner
RUNNER_DB_USER=runner
RUNNER_DB_PASSWORD=runner_secure_password
# For external Postgres: set POSTGRES_MODE=external and point RUNNER_DB_HOST
# at your DB host. Skip the bundled container by NOT passing --profile bundled-db.

# ── Jira Cloud (OPTIONAL — leave blank for built-in issue tracker) ───────────
# JIRA_DOMAIN=https://yourorg.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=your-jira-api-token

# ── Telegram (OPTIONAL — leave blank for in-app notifications only) ──────────
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_CHAT_NOTIFICATIONS=your-chat-id
# TELEGRAM_CHAT_ENGINEERING=your-chat-id
# TELEGRAM_CHAT_MARKETING=your-chat-id
# TELEGRAM_CHAT_SALES=your-chat-id

# ── N8N Workflow Automation (OPTIONAL — core runner works without it) ────────
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=strongpassword
# N8N_DB_PASSWORD=n8n_secure_password

# ── External Webhook Access (OPTIONAL) ───────────────────────────────────────
# NGROK_AUTHTOKEN=your-ngrok-authtoken
# NGROK_DOMAIN=your-domain.ngrok.app

# ── Outgoing Notification Webhook (OPTIONAL — Slack/Discord/Teams/custom) ────
# NOTIFICATION_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Project Directory (mounted into runner container) ────────────────────────
# PROJECT_DIR=/path/to/your/project

# ── API Keys (OPTIONAL) ─────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=your-anthropic-key  (only if using API mode instead of OAuth)
# ATTIO_API_KEY=your-attio-api-key      (for sales agents)
# ZAI_API_KEY=your-zai-api-key          (for creative-assets agent)
# SNYK_TOKEN=your-snyk-token            (for security scanning via Snyk MCP)
