# Claude Runner Environment Variables
# Copy this file to .env and fill in your values

# Required: Secret for API authentication
RUNNER_SECRET=your-runner-secret-here

# Z.ai API key (for ui-engineer and creative-assets agents)
# Get from: https://open.bigmodel.cn
ZAI_API_KEY=your-zai-api-key

# Note: ANTHROPIC_API_KEY is NOT needed if you have a Claude subscription
# Claude Code authenticates via your subscription automatically

# Optional: Override defaults from config.json
# PORT=3210
# HOST=127.0.0.1
# JOB_TIMEOUT_MINUTES=60
# MAX_CONCURRENCY=5
